rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /friends/{friendId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
                     && (request.auth.uid == userId || request.auth.uid == friendId);
      }
    }

    // ── Rounds ───────────────────────────────────────────────────────────────
    match /rounds/{roundId} {
      allow read:   if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Group rounds ─────────────────────────────────────────────────────────
    match /groupRounds/{sessionId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Swing jobs ───────────────────────────────────────────────────────────
    match /swingJobs/{jobId} {
      allow read:  if request.auth != null
                   && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null
                   && request.resource.data.userId == request.auth.uid;
    }

    // ── Active sessions (Nearby Players presence) ─────────────────────────
    match /active_sessions/{sessionUserId} {
      // Any authenticated user can read (needed for the discovery stream)
      allow read:  if request.auth != null;
      // Only the session owner may write their own presence doc
      allow write: if request.auth != null
                   && request.auth.uid == sessionUserId;
    }

    // ── Join requests ────────────────────────────────────────────────────────
    match /joinRequests/{requestId} {
      // Create: caller must be the sender
      allow create: if request.auth != null
                    && request.resource.data.fromUserId == request.auth.uid;
      // Read / update: sender or recipient only
      allow read:   if request.auth != null
                    && (resource.data.fromUserId == request.auth.uid
                        || resource.data.toUserId  == request.auth.uid);
      allow update: if request.auth != null
                    && (resource.data.fromUserId == request.auth.uid
                        || resource.data.toUserId  == request.auth.uid);
      // No deletes from clients
      allow delete: if false;
    }
  }
}
