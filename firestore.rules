rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /friends/{friendId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
                     && (request.auth.uid == userId || request.auth.uid == friendId);
      }
    }

    // ── Rounds ───────────────────────────────────────────────────────────────
    match /rounds/{roundId} {
      // Owner always has full read access.
      // Any authenticated user can read a round if:
      //   - it belongs to a group session, OR
      //   - they are in sharedWith, OR
      //   - they are reading someone else's rounds (for friends stats/leaderboard)
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Group rounds ─────────────────────────────────────────────────────────
    match /groupRounds/{sessionId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
