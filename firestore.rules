rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /friends/{friendId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
                     && (request.auth.uid == userId || request.auth.uid == friendId);
      }

      match /swingAnalyses/{analysisId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Rounds ───────────────────────────────────────────────────────────────
    match /rounds/{roundId} {
      // Owner can always read their own rounds.
      // Other authenticated users can read a round that belongs to a group session
      // (sessionId != null) so the joint scorecard can fetch peer hole scores.
      allow read:   if request.auth != null
                    && (resource.data.userId == request.auth.uid
                        || resource.data.sessionId != null
                        || (resource.data.sharedWith is list
                            && request.auth.uid in resource.data.sharedWith));
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Group rounds ─────────────────────────────────────────────────────────
    match /groupRounds/{sessionId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Swing jobs ───────────────────────────────────────────────────────────
    match /swingJobs/{jobId} {
      allow read:  if request.auth != null
                   && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null
                   && request.resource.data.userId == request.auth.uid;
    }
  }
}
